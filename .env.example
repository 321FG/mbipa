# Mbipa Environment Configuration
# Copy this file to .env and fill in your values

# Set to "true" to use mock data (no backend needed)
EXPO_PUBLIC_USE_MOCK=true

# API Backend
EXPO_PUBLIC_API_URL=https://mbipa-whatsapp-ecajgkctb4cxeyck.eastus-01.azurewebsites.net
API_VERSION=v1

# Azure AD B2C
EXPO_PUBLIC_AZURE_AD_CLIENT_ID=your_client_id
EXPO_PUBLIC_AZURE_AD_TENANT_ID=your_tenant_id
EXPO_PUBLIC_AZURE_AD_POLICY_SIGNIN=B2C_1_signin

# Azure Speech (pour avatar)
EXPO_PUBLIC_AZURE_SPEECH_KEY=your_speech_key
EXPO_PUBLIC_AZURE_SPEECH_REGION=westus2

# Stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# SignalR
EXPO_PUBLIC_SIGNALR_URL=https://mbipa-whatsapp-ecajgkctb4cxeyck.eastus-01.azurewebsites.net
