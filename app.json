{
  "expo": {
    "name": "Mbipa",
    "slug": "mbipa-app",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "mbipa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mbipa.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mbipa.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/MbipaUpdatedTrim.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/MbipaUpdatedTrim.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "",
          "enableGooglePay": true
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      "expo-audio",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Mbipa would like to glance at you for a gentle emotional check-in. You can decline anytime.",
          "photosPermission": "Mbipa needs access to your photos so you can pick an avatar."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7da7d2f-8a9c-49c0-b247-c8fe3a90cc94"
      }
    },
    "owner": "juliuschrys07",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e7da7d2f-8a9c-49c0-b247-c8fe3a90cc94"
    }
  }
}
